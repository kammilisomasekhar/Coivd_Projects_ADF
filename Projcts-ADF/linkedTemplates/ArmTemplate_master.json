{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "Projcts-ADF"
		},
		"Is_ablob_covidreportingsa_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Is_ablob_covidreportingsa'"
		},
		"Is_adls_covidreportingdl_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Is_adls_covidreportingdl'"
		},
		"Is_adls_covidreportingdl_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://dlprojectstrorage.dfs.core.windows.net/"
		},
		"Storage Events_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/ceac49aa-6e78-4024-931e-07e25263a010/resourceGroups/Project_Resource/providers/Microsoft.Storage/storageAccounts/blobcoived"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "Projcts-ADF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Is_ablob_covidreportingsa_connectionString": {
						"value": "[parameters('Is_ablob_covidreportingsa_connectionString')]"
					},
					"Is_adls_covidreportingdl_accountKey": {
						"value": "[parameters('Is_adls_covidreportingdl_accountKey')]"
					},
					"Is_adls_covidreportingdl_properties_typeProperties_url": {
						"value": "[parameters('Is_adls_covidreportingdl_properties_typeProperties_url')]"
					},
					"Storage Events_properties_typeProperties_scope": {
						"value": "[parameters('Storage Events_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}