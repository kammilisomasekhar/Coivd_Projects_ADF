{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "Projcts-ADF"
		},
		"Is_ablob_covidreportingsa_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Is_ablob_covidreportingsa'"
		},
		"Is_adls_covidreportingdl_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Is_adls_covidreportingdl'"
		},
		"Is_adls_covidreportingdl_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://dlprojectstrorage.dfs.core.windows.net/"
		},
		"Is_http_opendata_ecdc_europa_eu_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://opendata.ecdc.europa.eu/"
		},
		"Schedule_Trigger_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL": {
			"type": "string",
			"defaultValue": "covid19/hospitalicuadmissionrates/csv/data.csv"
		},
		"Schedule_Trigger_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name": {
			"type": "string",
			"defaultValue": "hospital_admission.csv"
		},
		"trigger1_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL": {
			"type": "string",
			"defaultValue": "covid19/hospitalicuadmissionrates/csv/data.csv"
		},
		"trigger1_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name": {
			"type": "string",
			"defaultValue": "hospital_admission.csv"
		},
		"trigger_1_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL": {
			"type": "string",
			"defaultValue": "covid19/hospitalicuadmissionrates/csv/data.csv"
		},
		"trigger_1_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name": {
			"type": "string",
			"defaultValue": "hospital_admission.csv"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "Projcts-ADF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Is_ablob_covidreportingsa_connectionString": {
						"value": "[parameters('Is_ablob_covidreportingsa_connectionString')]"
					},
					"Is_adls_covidreportingdl_accountKey": {
						"value": "[parameters('Is_adls_covidreportingdl_accountKey')]"
					},
					"Is_adls_covidreportingdl_properties_typeProperties_url": {
						"value": "[parameters('Is_adls_covidreportingdl_properties_typeProperties_url')]"
					},
					"Is_http_opendata_ecdc_europa_eu_properties_typeProperties_url": {
						"value": "[parameters('Is_http_opendata_ecdc_europa_eu_properties_typeProperties_url')]"
					},
					"Schedule_Trigger_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL": {
						"value": "[parameters('Schedule_Trigger_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL')]"
					},
					"Schedule_Trigger_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name": {
						"value": "[parameters('Schedule_Trigger_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name')]"
					},
					"trigger1_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL": {
						"value": "[parameters('trigger1_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL')]"
					},
					"trigger1_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name": {
						"value": "[parameters('trigger1_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name')]"
					},
					"trigger_1_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL": {
						"value": "[parameters('trigger_1_properties_PL_ingest_cases_death_data_Para_parameters_Source_URL')]"
					},
					"trigger_1_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name": {
						"value": "[parameters('trigger_1_properties_PL_ingest_cases_death_data_Para_parameters_Sink_File_name')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}